{
  "name": "dosha-companion-prototype",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "generate:quiz": "node scripts/generate-quiz-data.mjs",
    "generate:content": "node scripts/generate-content.mjs",
    "generate": "npm run generate:quiz && npm run generate:content",
    "predev": "npm run generate",
    "dev": "vite --host 0.0.0.0",
    "typecheck": "tsc -b",
    "lint": "oxlint .",
    "pretest": "npm run generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "npm run generate",
    "test:e2e": "playwright test",
    "prebuild": "npm run generate",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "maplibre-gl": "^5.24.0",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
